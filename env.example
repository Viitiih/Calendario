# .env.example — Firebase (substitui VITE_BACKEND_URL e VITE_STATIC_MODE)
# Renomeie este arquivo para .env e preencha com seus dados do Firebase Console
# Firebase Console → Project Settings → Your apps → Web app → SDK setup and configuration

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# As variáveis abaixo NÃO são mais necessárias após a migração para Firebase:
# VITE_BACKEND_URL=   ← removida
# VITE_STATIC_MODE=   ← removida
