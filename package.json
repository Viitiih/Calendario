{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:static": "set \"VITE_STATIC_MODE=true\" && vite",
    "build": "vite build",
    "deploy": "npm run build",
    "deploy:push": "npm run build && git add . && git commit -m \"deploy\" && git push",
    "preview": "vite preview",
    "serve:docs": "node serve-dist.mjs",
    "start": "node server.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
